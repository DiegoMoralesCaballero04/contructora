{
  "name": "CONSTRUTECH-IA — Trigger Scraping Diari",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * 1-5"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger (L-V 07:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://django:8000/api/v1/scraping/executar/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "filtres",
              "value": "{\"provincia\": \"Valencia\", \"importe_max\": 4000000}"
            },
            {
              "name": "max_pagines",
              "value": "15"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "http-trigger-scraping",
      "name": "POST /api/v1/scraping/executar/",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    },
    {
      "parameters": {
        "message": "=Scraping iniciat. Task ID: {{ $json.task_id }}",
        "additionalFields": {}
      },
      "id": "telegram-confirm",
      "name": "Telegram — Confirmar inici",
      "type": "n8n-nodes-base.telegram",
      "position": [750, 300]
    }
  ],
  "connections": {
    "Schedule Trigger (L-V 07:00)": {
      "main": [[{"node": "POST /api/v1/scraping/executar/", "type": "main", "index": 0}]]
    },
    "POST /api/v1/scraping/executar/": {
      "main": [[{"node": "Telegram — Confirmar inici", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
