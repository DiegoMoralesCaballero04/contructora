# ============================================================
# CONSTRUTECH-IA — Environment Variables Template
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# PostgreSQL
POSTGRES_DB=construtech
POSTGRES_USER=construtech
POSTGRES_PASSWORD=construtech_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=construtech_raw
MONGO_USER=
MONGO_PASSWORD=

# Redis (Celery broker)
REDIS_URL=redis://redis:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_STORAGE_BUCKET_NAME=construtech-licitaciones
AWS_S3_REGION_NAME=eu-south-2
AWS_S3_ENDPOINT_URL=

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# n8n (credencials del compte propietari - les que poses al setup inicial)
N8N_EMAIL=el-teu-email@exemple.com
N8N_PASSWORD=la-teva-contrasenya

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@construtech-ia.local

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Microsoft Graph API (Calendari Laboral)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/api/v1/calendari/oauth/callback/
SITE_URL=http://localhost:8000

# API
API_KEY=construtech-n8n-api-key-change-me
